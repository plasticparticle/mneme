# Copy to .env (gitignored) and adjust. These _dev defaults match docker-compose.yml.
DATABASE_URL=postgres://journal:journal_dev@localhost:5432/journal?sslmode=disable
LISTEN_ADDR=:8080
SESSION_TTL=24h

# CORS: comma-separated allowed origins, or "*" to reflect any (dev default).
# In production set this to your client origin(s), e.g. https://mneme.app
CORS_ORIGINS=*

# Media object storage (S3-compatible). Leave S3_ENDPOINT empty to run without
# media (media endpoints answer 503).
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_dev
S3_BUCKET=journal-media

# Admin dashboard (/admin): aggregate stats only, never per-user detail. Leave
# empty (or unset) to disable the admin surface entirely (every /admin path 404s).
# In production use a long random secret, e.g.: openssl rand -base64 32
ADMIN_TOKEN=admin_dev
