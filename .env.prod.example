# Production secrets/config — copy to .env.prod and fill in real values.
# .env.prod is gitignored; never commit it.

# Postgres superuser password (bookkeeping DB; opaque blobs only).
POSTGRES_PASSWORD=

# MinIO root credentials — also used by the relay as its S3 credentials.
MINIO_ROOT_USER=mneme
MINIO_ROOT_PASSWORD=

# Bearer token for the operator dashboard at /admin.
# Leave empty to disable the admin surface entirely (it 404s).
ADMIN_TOKEN=

# Operator approval for NEW vaults. Off by default = an open relay (anyone who
# can reach it can store their own encrypted journals on it). Set to true to run
# a single-tenant / hand-picked relay: a newly registered vault lands "pending"
# and can't sync until you approve it in /admin (so set ADMIN_TOKEN above too).
# Vaults that already exist are grandfathered to approved. See docs/API.md "Admin".
REQUIRE_APPROVAL=false

# The dashboard checks GitHub once/hour for a newer release and shows a banner
# when one exists (informational only — it never downloads or applies anything).
# This is the relay's only outbound call; set to off/false/0 to disable it for
# air-gapped deployments. Defaults to on.
UPDATE_CHECK=on

# Addresses Caddy answers on (comma-separated: LAN IP, hostname, …).
# The client bundle is hostname-agnostic, so add whatever your LAN resolves.
SITE_ADDRESS=192.168.68.71, cortex.local

# Certificate served when a client connects by bare IP (sends no SNI).
DEFAULT_SNI=

# Host directory where rolling backup archives land (created if missing).
BACKUP_HOST_DIR=/home/particle/mneme-backups

# Backup cadence and retention (newest first; 0 keeps all).
BACKUP_INTERVAL=24h
BACKUP_KEEP=14
